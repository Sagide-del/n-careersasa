{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install --include=dev && npm run build"
  },
  "deploy": {
    "startCommand": "cd backend && npm run start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
